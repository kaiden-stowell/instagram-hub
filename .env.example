# ─────────────────────────────────────────────────────────────────
# Instagram Hub configuration
# Mode is picked automatically based on which variables are set:
#   COMPOSIO_API_KEY set  → COMPOSIO mode  (recommended — no Meta app needed)
#   INSTAGRAM_TOKEN set   → LIVE mode      (direct Graph API)
#   neither               → MOCK mode      (seeded fake data)
# ─────────────────────────────────────────────────────────────────

# ── Composio (recommended) ──
# Get a key from https://app.composio.dev/developers
# Then connect your Instagram account in the Composio dashboard.
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=default

# ── Direct Graph API (alternative) ──
INSTAGRAM_TOKEN=
INSTAGRAM_BUSINESS_ID=

# ── Server ──
HOST=127.0.0.1
PORT=12790

# ── Claude Code binary (autodetected if blank) ──
CLAUDE_BIN=
